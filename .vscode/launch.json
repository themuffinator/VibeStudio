      "externalConsole": false,
      "stopAtEntry": false,
      "linux": {
        "MIMode": "gdb"
      },
      "osx": {
        "MIMode": "lldb"
      }
    },
    {
      "name": "VibeStudio: debug CLI help (Unix, no build)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/builddir/src/vibestudio",
